
# Homebrew — macOS only
[[ -f /opt/homebrew/bin/brew ]] && eval "$(/opt/homebrew/bin/brew shellenv)"

# Load shared config
for config in ~/.zsh/{path,env,aliases,completion,tools,prompt}.zsh; do
  [[ -f "$config" ]] && source "$config"
done

# Platform-specific aliases
if   [[ "$OSTYPE" == "darwin"* ]];     then source ~/.zsh/aliases.macos.zsh
elif [[ "$OSTYPE" == "linux-gnu"* ]];  then source ~/.zsh/aliases.linux.zsh
fi

# Machine-local overrides (not tracked in repo)
[[ -f ~/.env.local.zsh ]] && source ~/.env.local.zsh
